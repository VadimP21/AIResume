# =========================================================
# APP
# =========================================================

APP_NAME=resume-builder
APP_ENV=production
DEBUG=false
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
TIMEZONE=UTC
UV_CACHE_DIR=.uv-cache

# =========================================================
# FAKE AUTH
# =========================================================

ENABLE_FAKE_AUTH=false
FAKE_AUTH_EMAIL=
FAKE_AUTH_PASSWORD=
API_V1_PREFIX=/api/v1

# =========================================================
# POSTGRES
# =========================================================

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=resume_builder_db
POSTGRES_USER=resume_builder_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =========================================================
# REDIS
# =========================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# =========================================================
# JWT
# =========================================================

JWT_SECRET=CHANGE_ME_ULTRA_SECRET_KEY_32_CHARS_MINIMUM
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_SECONDS=604800
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=airesume-api
JWT_AUDIENCE=airesume-client

# =========================================================
# CORS
# =========================================================

CORS_ORIGINS=["http://localhost:3000"]

# =========================================================
# AI/LLM
# =========================================================

AI_PROVIDER=gemini
AI_REQUEST_TIMEOUT_SECONDS=30

GEMINI_API_KEY=
GEMINI_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

GIGACHAT_AUTH_KEY=
GIGACHAT_MODEL=
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

# =========================================================
# IMPORT/EXPORT
# =========================================================

RESUME_IMPORT_MAX_FILE_SIZE=5242880
